  <title>Admin Dashboard — TrackAssessment</title>
  <link rel="stylesheet" href="admin.css">
  <style>
    /* Keep the left sidebar visible while scrolling */
    .sidebar.card {
      position: sticky;
      top: 20px;
      align-self: flex-start;
      z-index: 10;
    }
    /* Keep the thin accent gradient bar aligned with the sidebar while scrolling */
    .accent-bar {
      position: sticky;
      top: 20px;
      align-self: flex-start;
      z-index: 9;
      /* ensure it stretches to match sidebar height; JS will set exact height */
      height: auto;
    }
  </style>
</head>
